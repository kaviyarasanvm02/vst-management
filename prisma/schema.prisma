// But appending with replace_file_content is hard if I don't want to read the whole file.
// I will just replace the User model block to add fields, and use write_to_file or a separate replace to append at the end.
// OR I can use a large replace if I include context.
// Let's replace the User model first.

model Project {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?
  isActive    Boolean @default(true)

  // Customer Relation
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Manager Relation
  managerId String?
  manager   User?   @relation("ProjectManager", fields: [managerId], references: [id])

  // Team Members
  teamMembers User[] @relation("ProjectTeam")

  remarks   String?
  startDate DateTime?
  endDate   DateTime?

  entries TimesheetEntry[]
  tasks   Task[]

  @@index([customerId])
  @@index([managerId])
}

model Timesheet {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  date       DateTime
  status     String           @default("PENDING") // PENDING, APPROVED, REJECTED
  entries    TimesheetEntry[]
  totalHours Float            @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([userId, date])
  @@index([status])
}

model TimesheetEntry {
  id          String    @id @default(cuid())
  timesheetId String
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  taskId      String?
  activity    String? // Added Activity
  location    String? // Added Location (e.g. Office, WFH)
  description String
  hours       Float

  @@index([timesheetId])
  @@index([projectId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH
  dueDate     DateTime?

  assignedToId String
  assignedTo   User   @relation("AssignedTasks", fields: [assignedToId], references: [id])

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignedToId])
  @@index([projectId])
  @@index([status])
}

model Leave {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime
  type      String   @default("LEAVE") // LEAVE, HOLIDAY, SICK
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reason    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([date])
}

model Branch {
  id         String   @id @default(cuid())
  name       String
  address    String?
  latitude   Float
  longitude  Float
  radius     Float    @default(100) // Meters
  shiftStart String   @default("09:00")
  shiftEnd   String   @default("18:00")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  users      User[]
}

model Attendance {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  date         DateTime
  clockIn      DateTime
  clockInLat   Float?
  clockInLng   Float?
  clockOut     DateTime?
  clockOutLat  Float?
  clockOutLng  Float?
  status       String    @default("PRESENT") // PRESENT, LATE, ABSENT, HALF_DAY
  ipAddress    String?
  punchMode    String    @default("OFFICE") // OFFICE, WFH, FIELD
  punchInNote  String? // Daily Goal
  punchOutNote String? // Work Summary
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([date])
}

model AttendanceRequest {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  attendanceId String? // Optional: if editing an existing record
  date         DateTime
  requestType  String // PUNCH_IN, PUNCH_OUT, CORRECTION
  newTime      DateTime
  reason       String
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  adminRemarks String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model SalaryStructure {
  id               String @id @default(cuid())
  userId           String @unique
  user             User   @relation(fields: [userId], references: [id])
  basic            Float  @default(0)
  hra              Float  @default(0)
  allowances       Float  @default(0)
  specialAllowance Float  @default(0)
  pf               Float  @default(0) // Employee Contribution
  pt               Float  @default(0) // Professional Tax
  deductions       Float  @default(0) // Other Deductions
  netSalary        Float  @default(0) // Approximate Net (for reference)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payroll {
  id          String @id @default(cuid())
  userId      String
  user        User   @relation(fields: [userId], references: [id])
  month       String // Format: "YYYY-MM"
  year        Int
  monthNumber Int

  basic         Float
  hra           Float
  allowances    Float
  grossEarnings Float

  pf              Float
  pt              Float
  deductions      Float
  totalDeductions Float

  netSalary Float

  totalDays   Int
  presentDays Float
  absentDays  Float
  lopDays     Float // Loss of Pay Days
  lopAmount   Float

  status      String    @default("DRAFT") // DRAFT, PROCESSED, PAID
  generatedAt DateTime  @default(now())
  paidAt      DateTime?

  items PayrollItem[]

  @@unique([userId, month])
  @@index([month])
  @@index([status])
}

model PayrollItem {
  id        String  @id @default(cuid())
  payrollId String
  payroll   Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  label     String
  amount    Float
  type      String // EARNING, DEDUCTION

  @@index([payrollId])
}
