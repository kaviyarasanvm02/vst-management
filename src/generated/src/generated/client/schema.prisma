// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id      String  @id @default(cuid())
  code    String  @unique
  name    String
  remarks String?
  users   User[]
}

model Customer {
  id            String    @id @default(cuid())
  code          String    @unique
  name          String
  address       String?
  remarks       String?
  contactPerson String?
  phone         String?
  email         String?
  projects      Project[]
}

model User {
  id       String  @id @default(cuid())
  code     String? @unique
  email    String  @unique
  password String
  name     String?
  image    String? // Path to profile avatar, e.g. /uploads/avatars/xxx.jpg

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])

  branch    String?
  phone     String?
  createdAt DateTime @default(now())

  timesheets Timesheet[]
  leaves     Leave[]

  // Project Relations
  managedProjects    Project[] @relation("ProjectManager")
  projectMemberships Project[] @relation("ProjectTeam")
  assignedTasks      Task[]    @relation("AssignedTasks")

  @@index([roleId])
}

model Project {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?
  isActive    Boolean @default(true)

  // Customer Relation
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Manager Relation
  managerId String?
  manager   User?   @relation("ProjectManager", fields: [managerId], references: [id])

  // Team Members
  teamMembers User[] @relation("ProjectTeam")

  remarks   String?
  startDate DateTime?
  endDate   DateTime?

  entries TimesheetEntry[]
  tasks   Task[]

  @@index([customerId])
  @@index([managerId])
}

model Timesheet {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  date       DateTime
  status     String           @default("PENDING") // PENDING, APPROVED, REJECTED
  entries    TimesheetEntry[]
  totalHours Float            @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([userId, date])
  @@index([status])
}

model TimesheetEntry {
  id          String    @id @default(cuid())
  timesheetId String
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  taskId      String?
  activity    String? // Added Activity
  location    String? // Added Location (e.g. Office, WFH)
  description String
  hours       Float

  @@index([timesheetId])
  @@index([projectId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH
  dueDate     DateTime?

  assignedToId String
  assignedTo   User   @relation("AssignedTasks", fields: [assignedToId], references: [id])

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignedToId])
  @@index([projectId])
  @@index([status])
}

model Leave {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime
  type      String   @default("LEAVE") // LEAVE, HOLIDAY, SICK
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reason    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([date])
}
